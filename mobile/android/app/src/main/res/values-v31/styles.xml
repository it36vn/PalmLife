<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="launch_background">#0D7C66</color>
    <color name="launch_background_start">#18AD86</color>

    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/launch_background_start</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/launch_image</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
